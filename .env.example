# Copy this file to .env and fill with your MongoDB Atlas values
# The connection URL is built as: URL_PRE + MONGODB_PWD + URL_POST

URL_PRE=mongodb+srv://<username>:
MONGODB_PWD=<password>
URL_POST=@<cluster-host>/?retryWrites=true&w=majority&appName=<app-name>

# Optional logger variables
# PINO_LOG_LEVEL=trace
# LOG_TO_CONSOLE_ONLY=true
